{
  "$schema": "https://tr.designtokens.org/format/",
  "version": "2.0.0",
  "designSystem": {
    "name": "Enterprise Application Design System",
    "description": "Comprehensive design tokens for workspace-based enterprise application",
    "baseUnit": {
      "spacing": "8px",
      "radius": "4px"
    }
  },
  "typography": {
    "display": {
      "extraLarge": {
        "fontSize": "3.75rem",
        "lineHeight": "1rem",
        "fontWeight": "700",
        "letterSpacing": "-2.5%",
        "class": "text-6xl font-bold"
      },
      "large": {
        "fontSize": "3rem",
        "lineHeight": "1rem",
        "fontWeight": "700",
        "letterSpacing": "-1.5%",
        "class": "text-5xl font-bold"
      }
    },
    "heading": {
      "h1": {
        "fontSize": "2.25rem",
        "lineHeight": "2.5rem",
        "fontWeight": "700",
        "letterSpacing": "-2.5%",
        "class": "text-4xl font-bold"
      },
      "h2": {
        "fontSize": "1.875rem",
        "lineHeight": "2.25rem",
        "fontWeight": "700",
        "letterSpacing": "-2.5%",
        "class": "text-3xl font-bold"
      },
      "h3": {
        "fontSize": "1.5rem",
        "lineHeight": "2rem",
        "fontWeight": "700",
        "letterSpacing": "-2.5%",
        "class": "text-2xl font-bold"
      },
      "h4": {
        "fontSize": "1.25rem",
        "lineHeight": "1.75rem",
        "fontWeight": "700",
        "letterSpacing": "-2.5%",
        "class": "text-xl font-bold"
      }
    },
    "label": {
      "large": {
        "fontSize": "1.125rem",
        "lineHeight": "1.75rem",
        "fontWeight": "500",
        "letterSpacing": "0%",
        "class": "text-lg font-medium"
      },
      "base": {
        "fontSize": "1rem",
        "lineHeight": "1.5rem",
        "fontWeight": "500",
        "letterSpacing": "0%",
        "class": "text-base font-medium"
      },
      "small": {
        "fontSize": "0.875rem",
        "lineHeight": "1.25rem",
        "fontWeight": "500",
        "letterSpacing": "0%",
        "class": "text-sm font-medium"
      },
      "tiny": {
        "fontSize": "0.75rem",
        "lineHeight": "1rem",
        "fontWeight": "500",
        "letterSpacing": "0%",
        "class": "text-xs font-medium"
      }
    },
    "body": {
      "large": {
        "fontSize": "1.125rem",
        "lineHeight": "1.75rem",
        "fontWeight": "400",
        "letterSpacing": "0%",
        "class": "text-lg font-normal"
      },
      "base": {
        "fontSize": "1rem",
        "lineHeight": "1.5rem",
        "fontWeight": "400",
        "letterSpacing": "0%",
        "class": "text-base font-normal"
      },
      "small": {
        "fontSize": "0.875rem",
        "lineHeight": "1.25rem",
        "fontWeight": "400",
        "letterSpacing": "0%",
        "class": "text-sm font-normal"
      },
      "tiny": {
        "fontSize": "0.75rem",
        "lineHeight": "1rem",
        "fontWeight": "400",
        "letterSpacing": "0%",
        "class": "text-xs font-normal"
      }
    }
  },
  "colors": {
    "grayscale": {
      "asphalt": {
        "25": "#FAFAFA",
        "100": "#F5F5F5",
        "200": "#E5E5E5",
        "300": "#D4D4D4",
        "400": "#A3A3A3",
        "500": "#737373",
        "600": "#525252",
        "700": "#404040",
        "800": "#262626",
        "900": "#171717"
      },
      "white": "#FFFFFF",
      "black": "#000000"
    },
    "semantic": {
      "success": {
        "25": "#F0FDF4",
        "400": "#4ADE80",
        "800": "#166534"
      },
      "attention": {
        "25": "#FEFCE8",
        "50": "#FEFCE8",
        "700": "#A16207",
        "900": "#713F12"
      },
      "danger": {
        "25": "#FEF2F2",
        "50": "#FEF2F2",
        "400": "#F87171",
        "500": "#EF4444",
        "600": "#DC2626",
        "800": "#991B1B"
      },
      "informative": {
        "25": "#EFF6FF",
        "50": "#EFF6FF",
        "600": "#2563EB",
        "800": "#1E40AF"
      },
      "copilot": {
        "500": "#F97316",
        "600": "#EA580C"
      },
      "pilot": {
        "25": "#ECFEFF",
        "700": "#0E7490"
      },
      "beta": {
        "25": "#FDF4FF",
        "700": "#A21CAF"
      }
    },
    "foreground": {
      "primary": {
        "light": "asphalt-900",
        "dark": "white"
      },
      "secondary": {
        "light": "asphalt-600",
        "dark": "asphalt-300"
      },
      "tertiary": {
        "light": "asphalt-500",
        "dark": "asphalt-400"
      },
      "disabled": {
        "light": "asphalt-400",
        "dark": "asphalt-500"
      },
      "inverse": {
        "light": "white",
        "dark": "asphalt-900"
      },
      "active": {
        "light": "asphalt-900",
        "dark": "white"
      },
      "activeHover": {
        "light": "asphalt-700",
        "dark": "asphalt-300"
      },
      "danger": {
        "light": "red-500",
        "dark": "red-400"
      }
    },
    "background": {
      "primary": {
        "light": "white",
        "dark": "asphalt-900"
      },
      "secondary": {
        "light": "asphalt-100",
        "dark": "asphalt-800"
      },
      "tertiary": {
        "light": "asphalt-200",
        "dark": "asphalt-700"
      }
    },
    "border": {
      "default": {
        "light": "asphalt-200",
        "dark": "asphalt-700"
      },
      "hover": {
        "light": "asphalt-900",
        "dark": "white"
      },
      "focus": {
        "light": "asphalt-900",
        "dark": "white"
      },
      "danger": {
        "light": "red-500",
        "dark": "red-600"
      },
      "active": {
        "light": "asphalt-900",
        "dark": "white"
      },
      "inactive": {
        "light": "asphalt-200",
        "dark": "asphalt-800"
      }
    }
  },
  "spacing": {
    "xs": {
      "value": "4px",
      "rem": "0.25rem",
      "multiplier": "0.5x",
      "class": "p-1, m-1, gap-1"
    },
    "s": {
      "value": "6px",
      "rem": "0.375rem",
      "multiplier": "0.75x",
      "class": "p-1.5, m-1.5, gap-1.5"
    },
    "base": {
      "value": "8px",
      "rem": "0.5rem",
      "multiplier": "1x",
      "class": "p-2, m-2, gap-2"
    },
    "lg": {
      "value": "12px",
      "rem": "0.75rem",
      "multiplier": "1.5x",
      "class": "p-3, m-3, gap-3"
    },
    "xl": {
      "value": "16px",
      "rem": "1rem",
      "multiplier": "2x",
      "class": "p-4, m-4, gap-4"
    },
    "2xl": {
      "value": "24px",
      "rem": "1.5rem",
      "multiplier": "3x",
      "class": "p-6, m-6, gap-6"
    },
    "3xl": {
      "value": "32px",
      "rem": "2rem",
      "multiplier": "4x",
      "class": "p-8, m-8, gap-8"
    },
    "4xl": {
      "value": "40px",
      "rem": "2.5rem",
      "multiplier": "5x",
      "class": "p-10, m-10, gap-10"
    },
    "5xl": {
      "value": "48px",
      "rem": "3rem",
      "multiplier": "6x",
      "class": "p-12, m-12, gap-12"
    },
    "6xl": {
      "value": "64px",
      "rem": "4rem",
      "multiplier": "8x",
      "class": "p-16, m-16, gap-16"
    }
  },
  "borderRadius": {
    "none": {
      "value": "0px",
      "class": "rounded-none"
    },
    "sm": {
      "value": "2px",
      "rem": "0.125rem",
      "multiplier": "0.5x",
      "class": "rounded-sm"
    },
    "base": {
      "value": "4px",
      "rem": "0.25rem",
      "multiplier": "1x",
      "class": "rounded"
    },
    "md": {
      "value": "6px",
      "rem": "0.375rem",
      "multiplier": "1.5x",
      "class": "rounded-md"
    },
    "lg": {
      "value": "8px",
      "rem": "0.5rem",
      "multiplier": "2x",
      "class": "rounded-lg"
    },
    "xl": {
      "value": "12px",
      "rem": "0.75rem",
      "multiplier": "3x",
      "class": "rounded-xl"
    },
    "2xl": {
      "value": "16px",
      "rem": "1rem",
      "multiplier": "4x",
      "class": "rounded-2xl"
    },
    "3xl": {
      "value": "24px",
      "rem": "1.5rem",
      "multiplier": "6x",
      "class": "rounded-3xl"
    },
    "full": {
      "value": "9999px",
      "class": "rounded-full"
    }
  },
  "components": {
    "button": {
      "small": {
        "padding": "px-2 py-1",
        "gap": "gap-1",
        "fontSize": "text-xs",
        "borderRadius": "rounded-sm"
      },
      "default": {
        "padding": "px-3 py-2",
        "gap": "gap-2",
        "fontSize": "text-sm",
        "borderRadius": "rounded"
      },
      "large": {
        "padding": "px-4 py-3",
        "gap": "gap-2",
        "fontSize": "text-base",
        "borderRadius": "rounded"
      },
      "variants": {
        "primary": {
          "background": "bg-asphalt-900 dark:bg-white",
          "text": "text-white dark:text-asphalt-900",
          "hover": "hover:bg-asphalt-800 dark:hover:bg-asphalt-200"
        },
        "secondary": {
          "background": "bg-transparent",
          "border": "border border-asphalt-200 dark:border-asphalt-700",
          "text": "text-asphalt-900 dark:text-white",
          "hover": "hover:border-asphalt-900 dark:hover:border-white"
        },
        "tertiary": {
          "background": "bg-transparent",
          "text": "text-asphalt-900 dark:text-white",
          "hover": "hover:bg-asphalt-100 dark:hover:bg-asphalt-800"
        },
        "copilot": {
          "background": "bg-transparent",
          "border": "border border-orange-500",
          "text": "text-orange-500",
          "hover": "hover:bg-orange-50 dark:hover:bg-orange-900/10"
        }
      }
    },
    "input": {
      "default": {
        "padding": "px-3 py-2",
        "fontSize": "text-sm",
        "borderRadius": "rounded",
        "border": "border border-asphalt-400 dark:border-asphalt-600",
        "hover": "hover:border-asphalt-900 dark:hover:border-white",
        "focus": "focus:border-asphalt-900 dark:focus:border-white focus:ring-1 focus:ring-asphalt-900 dark:focus:ring-white",
        "disabled": "disabled:bg-asphalt-100 disabled:border-asphalt-300"
      }
    },
    "card": {
      "compact": {
        "padding": "p-3",
        "gap": "gap-2",
        "borderRadius": "rounded-lg",
        "border": "border border-asphalt-200 dark:border-asphalt-700"
      },
      "default": {
        "padding": "p-4",
        "gap": "gap-3",
        "borderRadius": "rounded-lg",
        "border": "border border-asphalt-200 dark:border-asphalt-700"
      },
      "large": {
        "padding": "p-6",
        "gap": "gap-4",
        "borderRadius": "rounded-lg",
        "border": "border border-asphalt-200 dark:border-asphalt-700"
      }
    },
    "badge": {
      "small": {
        "padding": "px-1.5 py-0.5",
        "gap": "gap-1",
        "fontSize": "text-xs",
        "borderRadius": "rounded-sm"
      },
      "default": {
        "padding": "px-2 py-1",
        "gap": "gap-1",
        "fontSize": "text-xs",
        "borderRadius": "rounded-sm"
      },
      "large": {
        "padding": "px-3 py-1.5",
        "gap": "gap-1.5",
        "fontSize": "text-sm",
        "borderRadius": "rounded-sm"
      },
      "variants": {
        "success": {
          "background": "bg-green-800 dark:bg-green-25",
          "text": "text-green-400 dark:text-green-25",
          "border": "border border-white/0"
        },
        "attention": {
          "background": "bg-yellow-900 dark:bg-yellow-25",
          "text": "text-yellow-700 dark:text-yellow-25",
          "border": "border border-white/0"
        },
        "danger": {
          "background": "bg-red-800 dark:bg-red-25",
          "text": "text-red-500 dark:text-red-25",
          "border": "border border-white/0"
        },
        "informative": {
          "background": "bg-blue-800 dark:bg-blue-25",
          "text": "text-blue-600 dark:text-blue-25",
          "border": "border border-white/0"
        },
        "neutral": {
          "background": "bg-asphalt-700 dark:bg-asphalt-25",
          "text": "text-asphalt-700 dark:text-asphalt-25",
          "border": "border border-white/0"
        }
      }
    },
    "table": {
      "cell": {
        "padding": "px-3 py-2",
        "fontSize": "text-sm"
      },
      "header": {
        "padding": "px-3 py-2",
        "fontSize": "text-sm",
        "fontWeight": "font-medium"
      },
      "compact": {
        "cell": {
          "padding": "px-3 py-1.5",
          "fontSize": "text-sm"
        }
      }
    },
    "modal": {
      "container": {
        "padding": "p-6",
        "gap": "space-y-6",
        "borderRadius": "rounded-xl",
        "maxWidth": "max-w-2xl"
      }
    },
    "slideOut": {
      "container": {
        "borderRadius": "rounded-l-2xl",
        "width": "w-[600px]"
      },
      "header": {
        "padding": "px-6 py-4",
        "borderBottom": "border-b border-asphalt-200 dark:border-asphalt-700"
      },
      "content": {
        "padding": "px-6 py-4",
        "gap": "space-y-4"
      },
      "footer": {
        "padding": "px-6 py-4",
        "gap": "gap-3",
        "borderTop": "border-t border-asphalt-200 dark:border-asphalt-700"
      }
    },
    "popover": {
      "container": {
        "padding": "p-3",
        "gap": "gap-2",
        "borderRadius": "rounded-lg",
        "shadow": "shadow-lg",
        "border": "border border-asphalt-200 dark:border-asphalt-700"
      }
    },
    "tooltip": {
      "container": {
        "padding": "px-2 py-1",
        "fontSize": "text-xs",
        "borderRadius": "rounded",
        "background": "bg-asphalt-900 dark:bg-asphalt-700",
        "text": "text-white"
      }
    },
    "workspacePane": {
      "header": {
        "padding": "px-6 py-4",
        "gap": "gap-3",
        "borderBottom": "border-b border-asphalt-200 dark:border-asphalt-700"
      },
      "content": {
        "padding": "p-6",
        "gap": "space-y-4"
      }
    },
    "navigation": {
      "item": {
        "padding": "px-3 py-2",
        "gap": "gap-2",
        "fontSize": "text-sm",
        "borderRadius": "rounded"
      },
      "active": {
        "borderLeft": "border-l-2 border-orange-500",
        "background": "bg-asphalt-25 dark:bg-asphalt-25"
      },
      "inactive": {
        "borderLeft": "border-l-2 border-asphalt-100 dark:border-asphalt-900"
      }
    },
    "breadcrumbs": {
      "container": {
        "gap": "gap-2",
        "fontSize": "text-sm"
      },
      "item": {
        "text": "text-asphalt-600 dark:text-asphalt-300",
        "hover": "hover:text-asphalt-900 dark:hover:text-white"
      },
      "current": {
        "text": "text-asphalt-900 dark:text-white",
        "fontWeight": "font-medium"
      }
    },
    "banner": {
      "success": {
        "background": "bg-green-400 dark:bg-green-25",
        "border": "border-l-4 border-green-800",
        "padding": "p-4"
      },
      "attention": {
        "background": "bg-yellow-700 dark:bg-yellow-25",
        "border": "border-l-4 border-yellow-700 dark:border-yellow-50",
        "padding": "p-4"
      },
      "danger": {
        "background": "bg-red-500 dark:bg-red-25",
        "border": "border-l-4 border-red-500 dark:border-red-50",
        "padding": "p-4"
      },
      "informative": {
        "background": "bg-blue-600 dark:bg-blue-25",
        "border": "border-l-4 border-blue-600 dark:border-blue-50",
        "padding": "p-4"
      }
    }
  },
  "interactionPatterns": {
    "workspace": {
      "splitView": {
        "defaultRatio": "33% / 67%",
        "contextRatio": "67% / 33%",
        "description": "Grid left, Detail right for drill-down; Detail left, Context right for supplemental info"
      },
      "fullWorkspace": {
        "description": "Detail replaces Grid at 100% width for complex, self-contained views"
      },
      "slideOutDetail": {
        "description": "Temporary detail view overlays Grid, Grid becomes inert"
      }
    },
    "layering": {
      "hierarchy": [
        "Tooltip (read-only info)",
        "Rich Popover (quick in-context tasks)",
        "Slide-Out (focused sub-tasks)",
        "Modal (critical confirmations, destructive actions)"
      ]
    },
    "navigation": {
      "statefulHistory": {
        "shortcuts": {
          "back": "Cmd/Ctrl + [",
          "forward": "Cmd/Ctrl + ]"
        }
      },
      "commandPalette": {
        "shortcut": "Cmd/Ctrl + K"
      }
    }
  },
  "keyboardShortcuts": {
    "navigation": {
      "back": "Cmd/Ctrl + [",
      "forward": "Cmd/Ctrl + ]",
      "commandPalette": "Cmd/Ctrl + K"
    },
    "layers": {
      "close": "Esc"
    }
  }
}
